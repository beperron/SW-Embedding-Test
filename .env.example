# Copy this file to ".env" and fill in your own values. Never commit ".env".

# Your Supabase project URL and a read-only (anon/publishable) key.
# The pipeline reads the paper corpus over the public REST API with this key.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY

# Only needed if you want to write embeddings/metrics back to Supabase in bulk
# (the default "local-first" mode stores results on disk and does not need these):
# SUPABASE_SERVICE_KEY=
# SUPABASE_DB_URL=

# Required on Apple Silicon so unsupported operations fall back to CPU instead of crashing.
PYTORCH_ENABLE_MPS_FALLBACK=1

# Optional: only if you later add the proprietary OpenAI embedding comparator.
# OPENAI_API_KEY=
# Optional: for downloading gated Hugging Face models.
# HF_TOKEN=
